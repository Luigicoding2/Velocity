{
    "compilerOptions": {
        "resolveJsonModule": true,
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "allowJs": true,
        "lib": [
            "DOM",
            "DOM.Iterable",
            "esnext",
            "esnext.array",
            "esnext.asynciterable",
            "esnext.symbol"
        ],
        "module": "esnext",
        "moduleResolution": "bundler",
        "strict": true,
        "noImplicitAny": false,
        "target": "ESNEXT",
        "jsx": "preserve",
        "paths": {
            "@main/*": ["./src/main/*"],
            "@api/*": ["./src/api/*"],
            "@components/*": ["./src/components/*"],
            "@debug/*": ["./src/debug/*"],
            "@utils/*": ["./src/utils/*"],
            "@plugins/*": ["./src/plugins/*"],
            "@shared/*": ["./src/shared/*"],
            "@webpack/common": ["./src/webpack/common"],
            "@webpack/common/*": ["./src/webpack/common/*"],
            "@webpack": ["./src/webpack/webpack"],
            "@webpack/patcher": ["./src/webpack/patchWebpack"],
            "@webpack/wreq.d": ["./src/webpack/wreq.d"],
            "@webpack/types": ["./src/webpack/types"],
            "@velocity-types": [
                "./packages/velocity-types"
            ],
            "@velocity-types/*": [
                "./packages/velocity-types/*"
            ]
        },
        "plugins": [
            {
                "transform": "typescript-transform-paths",
                "afterDeclarations": true
            }
        ],
        "outDir": "who-fucking-cares-dude"
    },
    "include": [
        "src/**/*",
        "packages/**/*",
        "browser/**/*",
        "scripts/**/*",
        "eslint.config.mjs"
    ],
}
